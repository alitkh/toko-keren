# Copy to .env and fill from Firebase console (Project Settings > Your apps > Web app)
VITE_FB_API_KEY=xxx
VITE_FB_AUTH_DOMAIN=xxx.firebaseapp.com
VITE_FB_PROJECT_ID=xxx
VITE_FB_STORAGE_BUCKET=xxx.appspot.com
VITE_FB_MESSAGING_SENDER_ID=xxx
VITE_FB_APP_ID=xxx
# Realtime Database URL (Database > Realtime Database > Data)
VITE_FB_DATABASE_URL=https://xxx-default-rtdb.firebaseio.com
